{
  "name": "@level/qa-case-assignment-rule-run-visibility",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm run sync:mock-db-data:if-available",
    "dev": "next dev --port 3013",
    "prebuild": "pnpm run sync:mock-db-data:if-available",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "sync:mock-db-data": "node mock-db/scripts/export-activity-data.mjs",
    "sync:mock-db-data:if-available": "sh -c 'if command -v sqlite3 >/dev/null 2>&1; then pnpm run sync:mock-db-data; else echo \"sqlite3 not found; using committed mock-db-activity.ts\"; fi'",
    "db:inspect": "node mock-db/scripts/inspect-db.mjs",
    "db:verify-sync": "node mock-db/scripts/verify-ui-sync.mjs"
  },
  "dependencies": {
    "@level/ui": "workspace:*",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "shadcn": "^3.6.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
